{
  "name": "discord-channel-notifications",
  "version": "1.0.0",
  "description": "Discord bot to process voice channel join/leave events",
  "main": "bot.js",
  "type": "module",
  "scripts": {
    "start": "node bot-with-notifications.js",
    "dev": "node bot-with-notifications.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop discord-notifications",
    "pm2:restart": "pm2 restart discord-notifications",
    "pm2:logs": "pm2 logs discord-notifications"
  },
  "keywords": ["discord", "voice", "events"],
  "dependencies": {
    "discord.js": "^14.17.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "pm2": "^5.4.0"
  }
}
